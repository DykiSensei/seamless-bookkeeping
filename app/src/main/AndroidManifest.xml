<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 短信权限：读取银行交易短信 -->
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <!-- 通知监听不需要 uses-permission，是通过 BIND_NOTIFICATION_LISTENER_SERVICE 在 Service 上声明 -->
    <!-- 前台服务：保证抓取行为稳定，不被系统杀 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Android 13+ 通知权限（让 app 自身能发通知，比如预算超支提醒） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".BookkeepingApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BookkeepingApp">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.BookkeepingApp"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 通知监听服务：抓取支付宝/微信等的支付成功通知 -->
        <!-- BIND_NOTIFICATION_LISTENER_SERVICE 是系统级权限，只能由系统授予 -->
        <!-- 用户必须在「设置 - 通知 - 通知使用权」里手动勾选我们的应用 -->
        <service
            android:name=".notification.PaymentNotificationListenerService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- 前台保活服务：常驻通知 + 提高 NotificationListener 在国产 ROM 上的存活率 -->
        <!-- 默认不启动，由用户在「设置」里开启 -->
        <service
            android:name=".notification.KeepAliveService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- 无障碍兜底服务：抓微信转账/红包、支付宝转账入账等通知抓不到的场景 -->
        <!-- 默认未启用，用户必须在系统「无障碍」里手动勾选才会生效 -->
        <service
            android:name=".notification.accessibility.AccessibilityCaptureService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- 短信广播接收器：抓取银行交易短信 -->
        <!-- SMS_RECEIVED 是允许的"豁免隐式广播"，可以静态注册 -->
        <receiver
            android:name=".notification.SmsBroadcastReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>