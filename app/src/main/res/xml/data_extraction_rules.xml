<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) 数据备份与设备迁移规则。
  排除所有财务敏感数据，避免被自动同步到 Google Drive 或迁移到新设备。
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="bookkeeping.db" />
        <exclude domain="database" path="bookkeeping.db-shm" />
        <exclude domain="database" path="bookkeeping.db-wal" />
        <exclude domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="bookkeeping.db" />
        <exclude domain="database" path="bookkeeping.db-shm" />
        <exclude domain="database" path="bookkeeping.db-wal" />
        <exclude domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
